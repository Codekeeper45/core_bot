# ── LLM (OpenRouter) ────────────────────────────────────────────────
# STT + Vision + текстовый агент. Обязателен.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_FALLBACK_MODEL=

# ── LLM (DeepSeek, опционально) ─────────────────────────────────────
# Если задан DEEPSEEK_API_KEY — становится основным текстовым провайдером,
# OpenRouter остаётся как fallback (+ STT/Vision).
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── MySQL (подключи свою БД) ────────────────────────────────────────
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# ── Server ──────────────────────────────────────────────────────────
PORT=3000
BOT_NAME=AI-бот

# ── WhatsApp (Baileys) ──────────────────────────────────────────────
WA_AUTH_DIR=auth_info_baileys
WA_PAIRING_PHONE=

# Страница удалённой привязки /pair — задай случайный токен 16+ символов,
# иначе страница отдаёт 503. ENABLE_TUNNEL=1 поднимает Cloudflare Quick Tunnel.
PAIR_TOKEN=
ENABLE_TUNNEL=0

# ── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_URL=https://your-domain.com

# ── Instagram (Wazzup24) ────────────────────────────────────────────
WAZZUP_API_KEY=
WAZZUP_IG_CHANNEL_ID=
WAZZUP_WEBHOOK_SECRET=
WAZZUP_WEBHOOK_BASE_URL=
WAZZUP_WORKER_URL=
WAZZUP_POLL_INTERVAL_MS=3000

# ── Уведомления менеджеру (notify_manager) ──────────────────────────
MANAGER_WA=
MANAGER_GROUP_WA=
MANAGER_TG=
MANAGER_NAME=Менеджер
MANAGER_PUBLIC_CONTACT=

# ── Прочее ──────────────────────────────────────────────────────────
BLOCKED_PHONES=
EXCLUDED_CHAT_ID=
